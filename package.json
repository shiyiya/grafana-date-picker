{
  "name": "grafana-date-picker",
  "version": "1.0.2-alpha.0",
  "type": "module",
  "description": "A powerful React date range picker inspired by Grafana",
  "main": "dist/grafana-date-picker.umd.js",
  "module": "dist/grafana-date-picker.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/grafana-date-picker.es.js",
      "require": "./dist/grafana-date-picker.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "keywords": [
    "react",
    "date-picker",
    "date-range",
    "grafana",
    "typescript",
    "dayjs"
  ],
  "author": "Claude",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shiyiya/grafana-date-picker.git"
  },
  "bugs": {
    "url": "https://github.com/shiyiya/grafana-date-picker/issues"
  },
  "homepage": "https://shiyiya.github.io/grafana-date-picker",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "lucide-react": "^1.14.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^3.3.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:lib": "vite build --mode lib",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib && npm run build:types",
    "publish:lib": "node scripts/publish.js"
  }
}
